NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_GEOAPIFY_API_KEY=your-geoapify-api-key

# File-processing worker only. Never expose these values through NEXT_PUBLIC_*.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MALWARE_SCANNER_URL=https://scanner.example.com/scan
MALWARE_SCANNER_TOKEN=your-scanner-token
DOCUMENT_EXTRACTOR_URL=https://extractor.example.com/extract
DOCUMENT_EXTRACTOR_TOKEN=your-extractor-token
# Optional worker tuning:
# FILE_WORKER_ID=gridready-file-worker-1
# FILE_WORKER_BATCH_SIZE=5
# FILE_WORKER_POLL_MS=5000
# FILE_WORKER_TIMEOUT_MS=120000
# FILE_WORKER_MAX_FILE_BYTES=52428800
